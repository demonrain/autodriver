{
  "name": "magnet-metadata-platform",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/server",
    "apps/web",
    "packages/shared"
  ],
  "scripts": {
    "dev": "npm run dev -w @magnet/server",
    "dev:web": "npm run dev -w @magnet/web",
    "build": "npm run build -w @magnet/web && npm run build -w @magnet/server",
    "start": "npm run start -w @magnet/server",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.check.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "npm run db:migrate -w @magnet/server"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.6",
    "@node-rs/argon2": "^2.0.2",
    "@vitejs/plugin-react": "^5.1.1",
    "better-sqlite3": "^12.5.0",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.10.7",
    "lucide-react": "^0.561.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-router-dom": "^7.11.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.8",
    "jsdom": "^27.3.0",
    "playwright": "^1.61.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.16"
  }
}
